{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FlowstateCitationLabel",
  "oneOf": [
    {"$ref": "#/$defs/parsed_citation"},
    {"$ref": "#/$defs/rejected_input"}
  ],
  "$defs": {
    "rejected_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reject_reason", "evidence", "warnings"],
      "properties": {
        "status": {"const": "reject"},
        "reject_reason": {
          "type": "string",
          "enum": [
            "not_a_citation",
            "analytic_or_tag",
            "cross_reference_only",
            "too_malformed",
            "empty_or_placeholder"
          ]
        },
        "evidence": {"type": "string"},
        "warnings": {
          "type": "array",
          "items": {"$ref": "#/$defs/warning"}
        }
      }
    },
    "parsed_citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "authors",
        "year",
        "no_date",
        "published_date",
        "accessed_date",
        "retrieved_date",
        "title",
        "container_title",
        "publication",
        "publisher",
        "volume",
        "issue",
        "pages",
        "url",
        "doi",
        "database",
        "source_type",
        "card_signatures",
        "debate_annotations",
        "raw_tail",
        "spillover_start_index",
        "spillover_start_text",
        "warnings"
      ],
      "properties": {
        "status": {"const": "parsed"},
        "authors": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["index", "surname", "name", "qualifications"],
            "properties": {
              "index": {"type": "integer", "minimum": 0},
              "surname": {"type": ["string", "null"]},
              "name": {"type": ["string", "null"]},
              "qualifications": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          }
        },
        "year": {"type": ["integer", "null"], "minimum": 1000, "maximum": 2099},
        "no_date": {"type": "boolean"},
        "published_date": {"type": ["string", "null"]},
        "accessed_date": {"type": ["string", "null"]},
        "retrieved_date": {"type": ["string", "null"]},
        "title": {"type": ["string", "null"]},
        "container_title": {"type": ["string", "null"]},
        "publication": {"type": ["string", "null"]},
        "publisher": {"type": ["string", "null"]},
        "volume": {"type": ["string", "null"]},
        "issue": {"type": ["string", "null"]},
        "pages": {"type": ["string", "null"]},
        "url": {"type": ["string", "null"]},
        "doi": {"type": ["string", "null"]},
        "database": {"type": ["string", "null"]},
        "source_type": {
          "type": "string",
          "enum": [
            "journal_article",
            "law_review",
            "news_article",
            "web_page",
            "book",
            "book_chapter",
            "report",
            "thesis",
            "legal_source",
            "dictionary_or_reference",
            "interview",
            "unknown"
          ]
        },
        "card_signatures": {
          "type": "array",
          "items": {"type": "string"}
        },
        "debate_annotations": {
          "type": "array",
          "items": {"type": "string"}
        },
        "raw_tail": {"type": ["string", "null"]},
        "spillover_start_index": {"type": ["integer", "null"], "minimum": 0},
        "spillover_start_text": {"type": ["string", "null"]},
        "warnings": {
          "type": "array",
          "items": {"$ref": "#/$defs/warning"}
        },
        "_meta": {
          "type": "object",
          "description": "Labeler bookkeeping. NOT part of the seq2seq training target.",
          "additionalProperties": false,
          "properties": {
            "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
            "inferred_fields": {"type": "array", "items": {"type": "string"}}
          }
        }
      }
    },
    "warning": {
      "type": "string",
      "enum": [
        "incomplete_citation",
        "ambiguous_author",
        "ambiguous_author_qualification",
        "ambiguous_year",
        "conflicting_dates",
        "body_spillover",
        "trailing_debate_annotation",
        "url_only",
        "cross_reference_only",
        "no_date",
        "malformed",
        "possible_card_signature",
        "signature_note_fused",
        "unparsed_tail",
        "multiple_titles",
        "database_only",
        "page_range_ambiguous",
        "source_type_ambiguous",
        "not_a_citation",
        "et_al",
        "multiple_authors_unenumerated"
      ]
    }
  }
}
